# PayPal Credentials
# ==================
# Get these from https://developer.paypal.com/dashboard/applications
#
# Steps:
# 1. Log in to the PayPal Developer Dashboard
# 2. Go to Apps & Credentials
# 3. Create an App (or use an existing one)
# 4. Copy the Client ID and Secret below

PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# PayPal Mode
# ===========
# 'sandbox' = Testing mode (no real money, uses test accounts)
# 'live' = Production mode (processes real payments)
#
# ALWAYS start with sandbox for development and testing!

PAYPAL_MODE=sandbox

# Monthly Subscription Plan ID
# ============================
# Required for the "Full Cosmic Access" monthly subscription feature.
#
# To create a plan:
# 1. In PayPal Developer Dashboard, go to Sandbox > Subscriptions > Products & Plans
# 2. Create a Product first (e.g., "Celestial Eye Full Access")
# 3. Then create a Plan under that product (e.g., $9.99/month)
# 4. Copy the Plan ID (starts with P-) and paste it below
#
# See README.md for detailed instructions.

PAYPAL_SUBSCRIPTION_PLAN_ID=your_subscription_plan_id_here

# Server Port
# ===========
# Default: 3000
# Note: Render and other hosting platforms will set this automatically

PORT=3000
