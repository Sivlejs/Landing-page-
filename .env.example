# PayPal Credentials
# Get these from https://developer.paypal.com/developer/applications
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# PayPal Mode: 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# Monthly Subscription Plan ID (create in PayPal Developer Dashboard)
# See README for instructions on how to create a subscription plan
PAYPAL_SUBSCRIPTION_PLAN_ID=your_subscription_plan_id_here

# Server Port (Render will set this automatically)
PORT=3000
