# ============================================================
# Celestial Eye – Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Quick-start checklist:
#   Required (payments won't work without these two):
#   [1] PAYPAL_CLIENT_ID      → Your PayPal app's Client ID
#   [2] PAYPAL_CLIENT_SECRET  → Your PayPal app's Secret key
#
#   Optional (only needed for the monthly subscription feature):
#   [3] PAYPAL_SUBSCRIPTION_PLAN_ID → A PayPal billing plan ID
#
# Where to get them:
#   https://developer.paypal.com/dashboard/applications
#   (Create/open an app → copy Client ID and Secret)
# ============================================================

# [1] PayPal Client ID
# --------------------
# Visible in: Developer Dashboard → Apps & Credentials → your app
# This is the public identifier sent to the browser.

PAYPAL_CLIENT_ID=your_paypal_client_id_here

# [2] PayPal Client Secret
# ------------------------
# Visible in: Developer Dashboard → Apps & Credentials → your app → Show
# Keep this private – used only on the server to create/capture orders.

PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# [3] PayPal Mode
# ---------------
# 'sandbox' = Testing mode (no real money, uses sandbox accounts)
# 'live'    = Production mode (processes real payments)
#
# ALWAYS start with sandbox for development and testing!
# Set to 'live' when deploying to production (e.g. on Render, update render.yaml
# or your hosting platform's environment settings).

PAYPAL_MODE=sandbox

# [4] Monthly Subscription Plan ID
# ----------------------------------
# Required for the "Full Cosmic Access" monthly subscription.
# Format: starts with P-  (e.g. P-1AB23456CD789012EF345678)
#
# To create a plan:
#   1. Developer Dashboard → Sandbox → Subscriptions → Products & Plans
#   2. Create a Product (e.g. "Celestial Eye Full Access")
#   3. Create a Plan under that product (e.g. $3.99/month)
#   4. Copy the Plan ID (P-…) and paste it below
#
# See README.md for detailed step-by-step instructions.

PAYPAL_SUBSCRIPTION_PLAN_ID=your_subscription_plan_id_here

# [5] Server Port (optional)
# --------------------------
# Default: 3000
# Render and other hosting platforms set this automatically.

PORT=3000

# [6] PayPal Webhook ID
# ----------------------
# Required to verify webhook signatures in production.
# Steps to obtain:
#   1. Developer Dashboard → My Apps & Credentials → your app → Webhooks → Add Webhook
#   2. Set Webhook URL to: https://your-domain.com/api/paypal/webhook
#   3. Select events: PAYMENT.CAPTURE.COMPLETED, BILLING.SUBSCRIPTION.*
#   4. After saving, copy the Webhook ID shown in the list
# Leave blank during local development (signature verification is skipped).

PAYPAL_WEBHOOK_ID=
